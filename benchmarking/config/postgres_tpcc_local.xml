<!--
  Skeleton BenchBase configuration for running TPC-C against PostgreSQL
  (e.g., a postgres:latest Docker container started by
  benchmarking/scripts/run_postgres_tpcc_docker.sh).

  This file is intentionally incomplete. It is meant to:
    - capture the connection details and basic parameters for your setup,
    - remind you where to plug in values for TPC-C scale factor, terminals,
      and timing,
    - and encourage you to start from the official BenchBase
      config/postgres/sample_tpcc_config.xml when you want a fully
      featured configuration.

  Recommended process:
    1. Copy BenchBase's sample_tpcc_config.xml for PostgreSQL.
    2. Paste it here.
    3. Adjust only what you need (JDBC URL, user, password, scale factor,
       measurement time, etc.).

  Until then, this file serves as a placeholder documenting the key
  connection-related values for your Docker-based PostgreSQL setup.
-->

<benchbase>
  <!-- Database connection settings -->
  <database>
    <!--
      Adjust these values to match the container started by
      run_postgres_tpcc_docker.sh. The defaults there are:
        host: localhost
        port: 5432 (mapped from the container)
        database: tpcc
        user: postgres
        password: postgres
    -->
    <type>postgres</type>
    <driver>org.postgresql.Driver</driver>
    <url>jdbc:postgresql://localhost:5432/tpcc</url>
    <username>postgres</username>
    <password>postgres</password>
  </database>

  <!-- Workload section (TPC-C) -->
  <workload>
    <!--
      The exact structure of this section depends on BenchBase's
      expectations. Use the official sample_tpcc_config.xml as the
      authoritative source. Typical parameters include:
        - number of warehouses (scale factor)
        - number of terminals / concurrent clients
        - warmup time and measurement time
        - transaction mix configuration
    -->

    <!-- Example placeholders; replace with real elements from the
         official config when you are ready: -->
    <property>
      <name>warehouses</name>
      <value>TODO_SET_WAREHOUSES</value>
    </property>
    <property>
      <name>terminals</name>
      <value>TODO_SET_THREADS</value>
    </property>
    <property>
      <name>runMins</name>
      <value>TODO_SET_DURATION_MINUTES</value>
    </property>
  </workload>
</benchbase>
